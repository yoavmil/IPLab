<UserControl x:Class="IPLab.UI.Controls.DataInspectorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:IPLab.UI.ViewModels"
             xmlns:conv="clr-namespace:IPLab.UI.Converters">
    <UserControl.Resources>
        <conv:OperatorStatusToBrushConverter    x:Key="StatusToBrush"/>
        <conv:NullOrEmptyToCollapsedConverter   x:Key="NullOrEmptyToCollapsed"/>
        <conv:BoolToVisibilityConverter         x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: identity + status header -->
        <Border Grid.Row="0" Background="#252526" Padding="8,5"
                BorderBrush="#3F3F46" BorderThickness="0,0,0,1"
                Visibility="{Binding SelectedNode, Converter={StaticResource NullOrEmptyToCollapsed}}">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,7,0"
                         Fill="{Binding SelectedNode.Status, Converter={StaticResource StatusToBrush}}"/>
                <TextBlock Text="{Binding SelectedNode.Id}"
                           Foreground="#888888" FontFamily="Consolas" FontSize="11"
                           Margin="0,0,6,0"/>
                <TextBlock Text="{Binding SelectedNode.DisplayName}"
                           Foreground="#DCDCDC" FontFamily="Consolas" FontSize="11"
                           FontWeight="SemiBold" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding SelectedNode.TypeName}"
                           Foreground="#569CD6" FontFamily="Consolas" FontSize="11"/>
            </StackPanel>
        </Border>

        <!-- Row 1: error message (collapsed when empty) -->
        <Border Grid.Row="1" Background="#1A1A1A" Padding="8,4"
                BorderBrush="#3F3F46" BorderThickness="0,0,0,1"
                Visibility="{Binding SelectedNode.ErrorMessage, Converter={StaticResource NullOrEmptyToCollapsed}}">
            <TextBox Text="{Binding SelectedNode.ErrorMessage, Mode=OneWay}"
                     TextWrapping="Wrap"
                     Foreground="#FF6666"
                     FontFamily="Consolas" FontSize="11"
                     IsReadOnly="True"
                     Background="Transparent"
                     BorderThickness="0"
                     FocusVisualStyle="{x:Null}"/>
        </Border>

        <!-- Row 2: data tree -->
        <TreeView x:Name="DataTree"
                  Grid.Row="2"
                  ItemsSource="{Binding DataNodes}"
                  Background="#1E1E1E"
                  BorderThickness="0"
                  Padding="4"
                  PreviewMouseLeftButtonDown="OnTreeMouseDown"
                  PreviewKeyDown="OnTreeKeyDown">

            <TreeView.Resources>
                <!-- Dark selection/hover colours (WPF single-select highlight) -->
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"                      Color="#3A3D41"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"                  Color="#DCDCDC"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"     Color="#2D2D30"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#DCDCDC"/>

                <HierarchicalDataTemplate DataType="{x:Type vm:DataNodeViewModel}"
                                          ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal" Margin="0,1"
                                Tag="{Binding}">
                        <StackPanel.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Copy value"     Click="OnCopyValue"/>
                                <MenuItem Header="Copy all items" Click="OnCopyAllItems"
                                          Visibility="{Binding PlacementTarget.Tag.HasChildren,
                                              RelativeSource={RelativeSource AncestorType=ContextMenu},
                                              Converter={StaticResource BoolToVisibility}}"/>
                            </ContextMenu>
                        </StackPanel.ContextMenu>
                        <TextBlock Text="{Binding Name}"
                                   Foreground="#DCDCDC"
                                   FontFamily="Consolas" FontSize="11"
                                   MinWidth="130"/>
                        <TextBlock Text="{Binding ValueText}"
                                   Foreground="#CE9178"
                                   FontFamily="Consolas" FontSize="11"
                                   Margin="8,0,8,0"/>
                        <TextBlock Text="{Binding TypeText}"
                                   Foreground="#4EC9B0"
                                   FontFamily="Consolas" FontSize="11"/>
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.Resources>

            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded"     Value="{Binding IsExpanded, Mode=TwoWay}"/>
                    <Setter Property="Foreground"     Value="#DCDCDC"/>
                    <Setter Property="Background"     Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Style.Triggers>
                        <!-- Multi-select highlight: driven by DataNodeViewModel.IsSelected -->
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter Property="Background" Value="#3A3D41"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TreeView.ItemContainerStyle>
        </TreeView>
    </Grid>
</UserControl>
