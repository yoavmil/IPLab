<UserControl x:Class="IPLab.UI.Controls.InspectorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:rc="clr-namespace:RControls;assembly=RControls"
             xmlns:controls="clr-namespace:IPLab.UI.Controls">
    <TabControl Background="#252526" BorderBrush="#3F3F46"
                TabStripPlacement="Bottom">
        <TabItem Header="Image Preview">
            <Grid>
                <controls:OverlayImageViewer x:Name="ImageViewer"
                                             SourceImage="{Binding State.Image}"
                                             OverlayLayers="{Binding OverlayLayers}"
                                             OperationMode="Move"
                                             Background="#1E1E1E" />

                <ToggleButton x:Name="LayerToggle"
                              Content="&#x229E;"
                              Width="28" Height="24"
                              HorizontalAlignment="Right" VerticalAlignment="Top"
                              Margin="0,4,4,0"
                              Panel.ZIndex="1"
                              ToolTip="Toggle image layer visibility"
                              Background="#3C3C3C" Foreground="#CCCCCC"
                              BorderBrush="#555555" FontSize="14" />

                <Popup IsOpen="{Binding IsChecked, ElementName=LayerToggle}"
                       PlacementTarget="{Binding ElementName=LayerToggle}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True">
                    <Border Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="1"
                            Padding="10" MinWidth="260">
                        <StackPanel>
                            <TextBlock Text="LAYERS" Foreground="#888888"
                                       FontSize="10" FontWeight="Bold"
                                       Margin="0,0,0,6" />
                            <ItemsControl ItemsSource="{Binding OverlayLayers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <controls:LayerItemControl />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>
        </TabItem>
        <TabItem Header="Data">
            <Border Background="#1E1E1E" Padding="10">
                <TextBlock Text="{Binding SelectedNode.ErrorMessage}"
                           TextWrapping="Wrap"
                           Foreground="#FF6666"
                           FontFamily="Consolas"
                           FontSize="12"
                           VerticalAlignment="Top" />
            </Border>
        </TabItem>
    </TabControl>
</UserControl>
