<UserControl x:Class="IPLab.UI.Controls.ThumbnailStripControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:IPLab.UI.ViewModels"
             Visibility="{Binding HasImageStrip, Converter={StaticResource BoolToVis}}">
    <Border Background="#141414"
            BorderBrush="#3F3F46"
            BorderThickness="0 1 0 0">
        <DockPanel Height="96">

            <!-- Add button -->
            <Button DockPanel.Dock="Left"
                    Command="{Binding AddImageCommand}"
                    Content="+"
                    Width="32"
                    VerticalAlignment="Stretch"
                    Background="#2D2D30"
                    Foreground="#CCCCCC"
                    BorderBrush="#555555"
                    FontSize="20"
                    FontWeight="Light"
                    Cursor="Hand"
                    ToolTip="Add images to the list" />

            <!-- Thumbnail scroll -->
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Thumbnails}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ThumbnailItemViewModel}">
                            <Grid Width="96" Margin="3 4">
                                <!-- Highlight border for active image -->
                                <Border Cursor="Hand">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderThickness" Value="2" />
                                            <Setter Property="BorderBrush"     Value="Transparent" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="BorderBrush" Value="#007ACC" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Image Source="{Binding Thumbnail}"
                                           Height="80"
                                           Stretch="UniformToFill"
                                           ToolTip="{Binding FilePath}">
                                        <Image.InputBindings>
                                            <MouseBinding Gesture="LeftClick"
                                                          Command="{Binding SelectCommand}" />
                                        </Image.InputBindings>
                                    </Image>
                                </Border>

                                <!-- Remove button (top-right corner) -->
                                <Button HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Command="{Binding RemoveCommand}"
                                        Content="✕"
                                        Width="18" Height="18"
                                        Padding="0"
                                        Margin="0"
                                        FontSize="9"
                                        Background="#AA1E1E1E"
                                        Foreground="#AAAAAA"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        ToolTip="Remove from list" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
