<Window x:Class="IPLab.UI.Dialogs.TemplateEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:rc="clr-namespace:RControls;assembly=RControls"
        Title="Template Editor"
        Width="1100" Height="700"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        Foreground="#DCDCDC">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Margin="0 0 0 8" Foreground="#AAAAAA"
                   Text="Draw a template rectangle on the source image and click Apply Selection. On the template, draw rectangles over pixels to exclude. Right-click commits a drawn rectangle; Delete removes selected masks." />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox Header="Source Image" Foreground="#DCDCDC" BorderBrush="#444444">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="6">
                        <Button Content="Select Template" Click="OnSelectTemplate" Padding="8 4" Margin="0 0 6 0" />
                        <Button Content="Apply Selection" Click="OnApplySelection" Padding="8 4" />
                    </StackPanel>
                    <rc:ImageViewer x:Name="SourceViewer" Grid.Row="1"
                                    Background="Black" OperationMode="Move"
                                    IsDrawable="True" IsSelectable="True" />
                </Grid>
            </GroupBox>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" />

            <GroupBox Grid.Column="2" Header="Template and Mask" Foreground="#DCDCDC" BorderBrush="#444444">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="6">
                        <Button Content="Add Mask Rectangle" Click="OnAddMask" Padding="8 4" Margin="0 0 6 0" />
                        <Button Content="Delete Selected" Click="OnDeleteSelected" Padding="8 4" Margin="0 0 6 0" />
                        <Button Content="Clear Masks" Click="OnClearMasks" Padding="8 4" />
                    </StackPanel>
                    <rc:ImageViewer x:Name="TemplateViewer" Grid.Row="1"
                                    Background="Black" OperationMode="Move"
                                    IsDrawable="True" IsSelectable="True" />
                </Grid>
            </GroupBox>
        </Grid>

        <DockPanel Grid.Row="2" Margin="0 10 0 0">
            <TextBlock x:Name="PathText" VerticalAlignment="Center" Foreground="#888888"
                       TextTrimming="CharacterEllipsis" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="Save" Click="OnSave" Padding="12 5" Margin="6 0 0 0" />
                <Button Content="Save As..." Click="OnSaveAs" Padding="12 5" Margin="6 0 0 0" />
                <Button Content="Close" Click="OnClose" Padding="12 5" Margin="6 0 0 0" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
