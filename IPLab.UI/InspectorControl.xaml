<UserControl x:Class="IPLab.UI.InspectorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:rc="clr-namespace:RControls;assembly=RControls">
    <TabControl Background="#252526" BorderBrush="#3F3F46"
                TabStripPlacement="Bottom">
        <TabItem Header="Image Preview">
            <rc:ImageViewer x:Name="ImageViewer"
                            SourceImage="{Binding SelectedImage}"
                            OperationMode="Move"
                            Background="#1E1E1E" />
        </TabItem>
        <TabItem Header="Data">
            <Border Background="#1E1E1E" Padding="10">
                <TextBlock Text="{Binding SelectedNode.ErrorMessage}"
                           TextWrapping="Wrap"
                           Foreground="#FF6666"
                           FontFamily="Consolas"
                           FontSize="12"
                           VerticalAlignment="Top" />
            </Border>
        </TabItem>
    </TabControl>
</UserControl>
