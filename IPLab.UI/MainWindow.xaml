<Window x:Class="IPLab.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:IPLab.UI.Controls"
        Title="IPLab" Height="720" Width="1280"
        Background="#1E1E1E" Foreground="#DCDCDC">

    <DockPanel>

        <!-- ── Ribbon ─────────────────────────────────────────────────── -->
        <controls:RibbonControl DockPanel.Dock="Top" />

        <!-- ── Status bar ──────────────────────────────────────────────── -->
        <StatusBar DockPanel.Dock="Bottom" Background="#007ACC">
            <StatusBarItem>
                <TextBlock Text="{Binding Status}" Foreground="White" />
            </StatusBarItem>
        </StatusBar>

        <!-- ── Main split: Toolbox | Pipeline Editor | Inspector ──────────── -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="140" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="2*" MinWidth="300" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="380" MinWidth="200" />
            </Grid.ColumnDefinitions>

            <!-- Toolbox -->
            <controls:ToolboxControl Grid.Column="0" DataContext="{Binding Toolbox}" />

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch"
                          Background="#3F3F46" />

            <!-- Pipeline Editor -->
            <controls:PipelineEditorControl Grid.Column="2" />

            <GridSplitter Grid.Column="3" HorizontalAlignment="Stretch"
                          Background="#3F3F46" />

            <!-- Inspector -->
            <controls:InspectorControl Grid.Column="4" />
        </Grid>

    </DockPanel>
</Window>
